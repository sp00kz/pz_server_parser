# Copy this file to `pz.env.local` and fill in your own values:
#
#     cp pz.env.local.example pz.env.local
#
# Format is KEY=VALUE, one per line. Real environment variables take precedence
# over anything set here. `pz.env.local` is gitignored, so nothing personal is
# committed.

# Name written into each page's <meta name="author"> tag.
# Leave unset (or delete the line) to emit no author tag at all.
PZ_AUTHOR=Your Name

# Absolute URL where the finished site is published, no trailing slash.
# Required by build_sitemap.py.
PZ_SITE_URL=https://USERNAME.github.io/REPO

# URL shown in every page footer as a "build your own" link back to this
# generator. Defaults to the upstream project repo; point it at your own fork, or
# set it to an empty value to hide the footer link entirely.
PZ_TOOL_URL=https://github.com/USERNAME/REPO

# Browser User-Agent for the wiki API calls (needed to pass pzwiki's Cloudflare).
# A sensible default ships in pzenv.py; override only if you need to.
# PZ_UA=Mozilla/5.0 (...) Chrome/124.0 Safari/537.36

# --- Optional path overrides --------------------------------------------------
# These are auto-detected for a default Steam install (see README). Uncomment and
# set only if auto-detection cannot find them on your machine.
#
# PZ_MEDIA=/path/to/Steam/steamapps/common/ProjectZomboid/media
# PZ_REPO=/path/to/your/published/site/checkout
# PZ_WORKSHOP=/path/to/Steam/steamapps/workshop/content/108600
